class Solution {
public:
    int firstUniqChar(string s) {

        vector<int> nums(26,0);
        char ch;

     for(int i=0; i<s.size(); i++)

      { ch=s[i]; 
        nums[ch-'a']++; 
   
       }

       for(int i=0; i<s.size(); i++)
       {  ch=s[i]; 
        if(nums[ch-'a']==1)
        {
            return  i;
        }
       }

       return -1;
        
    }
};
