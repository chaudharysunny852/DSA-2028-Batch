class Solution {
public:
    bool isAnagram(string s, string t) {
        char ch;
        vector<int> nums(26,0);
        if(s.size()!=t.size())
        {
            return false;
        }

        for(int i=0; i<s.size(); i++)

      { ch=s[i]; 
        nums[ch-'a']++; 
   
       }
       for(int i=0; i<t.size(); i++)

      { ch=t[i]; 
        nums[ch-'a']--; 
   
       }
       for(int i=0; i<26; i++)
       {
        if(nums[i]!=0)
        {
            return false;
        }
       }
       return true;

        
    }
};
