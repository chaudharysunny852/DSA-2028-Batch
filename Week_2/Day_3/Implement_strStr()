class Solution {
public:
    int strStr(string haystack, string needle) {

        if (needle.size() > haystack.size()) {
            return -1;
        }

        int k = needle.size();

        for (int i = 0; i <= haystack.size() - k; i++) {

            int j = 0;

            while (j < k && haystack[i + j] == needle[j]) {
                j++;
            }

            if (j == k) {
                return i;
            }
        }

        return -1;
    }
};
